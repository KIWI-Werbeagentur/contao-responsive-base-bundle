{% extends "@Contao/mod_article.html5" %}

{% set container_classes = getAllContainerClasses(_context, table='tl_article')|join(" ") %}
{% set inner_classes =
    [
        responsiveContainerSize ? getRowClass(),
        getAllInnerContainerClasses(_context, table='tl_article')|join(" ")
    ]
%}
{% set spacingTopClasses = getSpacingClasses(responsiveSpacingTop|default(''), 't') %}
{% set spacingBottomClasses = getSpacingClasses(responsiveSpacingBottom|default(''), 'b') %}
{% set articleWrapperAttributes = articleWrapperAttributes|default(attrs()) %}
{# move the spacing to 'mod_article__main' when using a background element #}
{% if background and hasBackground(background) and not backgroundOverwrite %}
    {% set articleMainAttributes = articleMainAttributes|default(attrs()) %}
    {% if spacingTopClasses %}
        {% set articleMainAttributes = articleMainAttributes.set("data-spacing-top") %}
    {% endif %}
    {% if spacingBottomClasses %}
        {% set articleMainAttributes = articleMainAttributes.set("data-spacing-bottom") %}
    {% endif %}
{% else %}
    {% if spacingTopClasses %}
        {% set articleWrapperAttributes = articleWrapperAttributes.set("data-spacing-top") %}
    {% endif %}
    {% if spacingBottomClasses %}
        {% set articleWrapperAttributes = articleWrapperAttributes.set("data-spacing-bottom") %}
    {% endif %}
{% endif %}

{% block content %}
    <div class="mod_article__wrapper wrapper {{ container_classes }}" {{ articleWrapperAttributes }}>
        <div class="mod_article__inside inside {{ inner_classes|join(" ") }}">
            {{ parent() }}
        </div>
    </div>
{% endblock %}
