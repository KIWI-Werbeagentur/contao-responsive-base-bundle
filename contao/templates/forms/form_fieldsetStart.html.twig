{% set raw = this.class|default %}
{% set parts = raw|split('data-cff-condition="', 2) %}
{% set cffCondition = (parts|length > 1) ? parts[1]|split('"', 2)[0] : '' %}
{% set cleanClasses = parts[0]|replace({'"': ''})|trim %}

{% set fieldsetAttrs = attrs()
    .addClass('fieldset formbody__area')
    .addClass(cleanClasses)
    .addClass(getContainerClasses(this.responsiveContainer, type=this.type, table='tl_form_field'))
    .addClass(getAllResponsiveClasses(this, table='tl_form_field'), not this.responsiveContainer)
    .addClass(getOrderClasses(this.responsiveOrder), this.responsiveContainer)
    .addClass(getAlignSelfClasses(this.responsiveAlignSelf), this.responsiveContainer)
    .setIfExists('data-cff-condition', cffCondition)
    .mergeWith(fieldsetAttrs|default)
%}

<fieldset{{ fieldsetAttrs }}>
    <div class="fieldset__inside {{ getAllInnerContainerClasses(this, table='tl_form_field')|join(' ') }}">
        {% if this.label %}
            <legend>{{ this.label|insert_tag_raw }}</legend>
        {% endif %}
